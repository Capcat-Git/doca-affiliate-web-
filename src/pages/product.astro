---

<Layout title="Kệ Đồ Chữa Lành | doca.pet" description="Tổng hợp sản phẩm tiếp thị liên kết (Affiliate) tốt lành, chất lượng cao dành riêng cho Boss và Sen. Mời cô chú lựa chọn thong thả.">
  <script is:inline define:vars={{ supabaseUrl, supabaseKey }}>
    window.PUBLIC_SUPABASE_URL = supabaseUrl;
    window.PUBLIC_SUPABASE_ANON_KEY = supabaseKey;
  </script>

  <main class="product-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text active">Sản phẩm</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link active"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <!-- Curated Shelf section -->
    <section class="shelf-section single-page-shelf">
      <div class="container">
        <div class="shelf-header">
          <div class="shelf-header-illustration-wrapper">
            <img src="/images/pet-food-bags.png" alt="Kệ đồ chữa lành" class="shelf-header-illustration" />
          </div>
          <div class="shelf-header-info">
            <h1 class="title-large shelf-title">Kệ Đồ Chữa Lành</h1>
            <p class="shelf-subtitle">Thức quả lành tính, đong đầy yêu thương cho Boss & Sen 🐾</p>
          </div>
        </div>

        <!-- Các tab phân loại (Catalogue Tabs) -->
        <div class="category-tabs-container">
          <button class="tab-btn active" data-category="all">
            <i class="ph-light ph-circles-four tab-icon-ph"></i> Tất cả
          </button>
          <button class="tab-btn" data-category="thuc_an">
            <img src="/images/pate-cans.png" class="tab-icon" alt="" /> Thức Ăn Mèo
          </button>
          <button class="tab-btn" data-category="vat_pham">
            <img src="/images/pate-dog.png" class="tab-icon" alt="" /> Vật Phẩm Chăm Sóc
          </button>
          <button class="tab-btn" data-category="sach">
            <img src="/images/clay-book.png" class="tab-icon" alt="" /> Sách Chữa Lành
          </button>
          <button class="tab-btn" data-category="phu_kien">
            <img src="/images/pet-bowls.png" class="tab-icon" alt="" /> Phụ Kiện Nhà Ở
          </button>
        </div>
        
        <div class="products-grid">
          {products.map(product => (
            <ProductCard 
              id={product.id}
              slug={product.slug}
              name={product.name}
              category={getCategoryLabel(product.category)}
              categoryRaw={product.category}
              price={product.price}
              wholesalePrice={product.wholesale_price}
              minGroupSize={product.min_group_size}
              affiliateUrl={product.affiliate_url}
              imageUrl={product.image_url}
              quote={product.quote}
            />
          ))}
        </div>

        <!-- Phân trang sản phẩm (Pagination) -->
        <div id="products-pagination" class="products-pagination"></div>

        <!-- Description at bottom -->
        <p class="shelf-desc-bottom">
          Pate béo ngậy, hạt thơm ngon và vô vàn chiếc "ôm ấm áp" vỗ về sức khỏe Boss, xoa dịu tâm hồn Sen. Mời cô chú thong thả ghé lựa, tụi con cam kết hạt chuẩn cơm lành, Boss ăn là thích mê! 🐾
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Single Page Styles */
  .product-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-warm-light);
    padding-bottom: 4rem;
  }

  .single-page-shelf {
    padding-top: 3rem;
  }

  .nav-link-text.active,
  .mobile-menu-link.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  .back-link-wrapper {
    margin-bottom: 1.5rem;
  }
</style>

<script>
  // Client-side interactions for tabs, pagination, and menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. CATALOGUE FILTER & PAGINATION ---
    const tabBtns = document.querySelectorAll('.category-tabs-container .tab-btn');
    const productGrid = document.querySelector('.products-grid');
    const productCards = productGrid ? productGrid.children : [];
    const paginationContainer = document.getElementById('products-pagination');
    
    let currentCategory = 'all';
    let currentPage = 1;
    const itemsPerPage = 10;
    
    function updateGrid() {
      if (!productCards.length) return;

      const filteredCards = Array.from(productCards).filter(card => {
        const cardInner = card.classList.contains('product-card-v2') ? card : card.querySelector('.product-card-v2');
        if (!cardInner) return false;
        const categoryRaw = cardInner.getAttribute('data-category-raw') || '';
        if (currentCategory === 'all') return true;
        return categoryRaw === currentCategory;
      });
      
      const totalItems = filteredCards.length;
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      
      if (currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
      
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      
      // Hide all first
      Array.from(productCards).forEach(card => {
        (card as HTMLElement).style.display = 'none';
      });
      
      // Show filtered page items
      filteredCards.forEach((card, index) => {
        if (index >= startIndex && index < endIndex) {
          (card as HTMLElement).style.display = 'block';
        }
      });
      
      // Render pagination
      renderPagination(totalPages);
    }
    
    function renderPagination(totalPages: number) {
      if (!paginationContainer) return;
      
      if (totalPages <= 1) {
        paginationContainer.innerHTML = '';
        paginationContainer.style.display = 'none';
        return;
      }
      
      paginationContainer.style.display = 'flex';
      let html = '';
      
      // Prev
      html += `<button class="page-btn prev-btn" ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}"><i class="ph-light ph-caret-left"></i></button>`;
      
      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        html += `<button class="page-btn num-btn ${currentPage === i ? 'active' : ''}" data-page="${i}">${i}</button>`;
      }
      
      // Next
      html += `<button class="page-btn next-btn" ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}"><i class="ph-light ph-caret-right"></i></button>`;
      
      paginationContainer.innerHTML = html;
      
      // Events
      paginationContainer.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          if (target.disabled) return;
          const pageNum = parseInt(target.getAttribute('data-page') || '1');
          currentPage = pageNum;
          updateGrid();
          
          const shelfSection = document.querySelector('.shelf-section');
          shelfSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }
    
    // Tab event handlers
    tabBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        tabBtns.forEach(b => b.classList.remove('active'));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add('active');
        
        currentCategory = target.getAttribute('data-category') || 'all';
        currentPage = 1;
        updateGrid();
      });
    });
    
    // Initial run
    updateGrid();
  });
</script>
