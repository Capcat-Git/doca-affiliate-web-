---
import Layout from '../layouts/Layout.astro';
import familyData from '../data/family.json';

// Tải danh sách hình ảnh gia đình từ JSON
const familyPhotos = familyData;
---

<Layout 
  title="Góc Nhỏ Gia Đình | doca.pet" 
  description="Nơi cất giữ những khoảnh khắc ấm áp và mộc mạc của gia đình nhà DOCA. Mời cô chú lật xem từng bức ảnh chụp kỷ niệm của tụi con nhé. 🐾"
>
  <!-- Nhúng Google Fonts cho chữ viết tay mặt sau Polaroid -->
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&family=Patrick+Hand&display=swap" rel="stylesheet" />

  <main class="family-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text">Sản phẩm</a>
            <a href="/family" class="nav-link-text active">Gia đình</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/family" class="mobile-menu-link active"><i class="ph-light ph-users"></i> Gia đình</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <div class="container content-container">
      <!-- Header góc gia đình -->
      <div class="family-header animate-fade-in">
        <h1 class="family-page-title">Góc Nhỏ Gia Đình</h1>
        <p class="family-page-subtitle animate-fade-in-delayed">
          mỗi bức ảnh là một lát cắt thời gian dịu êm mẹ Lin chụp cho tụi con...<br />
          cô chú nhấp nhẹ vào từng tấm ảnh để đọc những dòng nhật ký viết tay ở mặt sau nhé. 🐾
        </p>
      </div>

      <!-- Pinterest-style Masonry Grid -->
      <div class="family-masonry-grid">
        {familyPhotos.map((photo) => (
          <div class="polaroid-card" data-id={photo.id}>
            <div class="polaroid-card-inner">
              
              <!-- Mặt trước: Ảnh Polaroid truyền thống -->
              <div class="card-front">
                <div class="polaroid-frame">
                  <div class="photo-wrapper" style={`aspect-ratio: ${photo.aspectRatio || '1/1'};`}>
                    <img src={photo.imageUrl} alt={photo.title} class="polaroid-photo" loading="lazy" />
                  </div>
                  <div class="polaroid-caption">
                    <span class="caption-text">{photo.title}</span>
                  </div>
                </div>
              </div>

              <!-- Mặt sau: Ghi chú viết tay trên giấy kẻ dòng vintage -->
              <div class="card-back">
                <div class="note-paper">
                  <div class="note-pattern">
                    <div class="lined-content">
                      <p class="note-handwritten">{photo.note}</p>
                    </div>
                    <div class="note-footer">
                      <span class="note-date">Lin & Mum 🐾</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  // Kích hoạt tính năng click/touch để lật ảnh (3D Flip toggle) và đóng mở mobile menu
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. POLAROID CARD FLIP ---
    const cards = document.querySelectorAll('.polaroid-card');
    
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        
        const inner = card.querySelector('.polaroid-card-inner');
        if (inner) {
          inner.classList.toggle('is-flipped');
        }
      });
    });
  });
</script>

<style>
  .family-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-beige);
    padding-bottom: 5rem;
  }

  /* Navbar Styles matching product.astro */
  .navbar {
    background-color: rgba(251, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cozy-border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 0;
    box-shadow: 0 1px 3px rgba(21, 23, 15, 0.04);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link-text:hover {
    color: var(--cozy-green-matcha-forest);
  }

  .nav-link-text.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
    transition: transform 0.3s ease;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--cozy-text-obsidian);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links-desktop {
    display: none; /* Hidden on mobile */
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none; /* Hidden on desktop */
    }
  }

  /* Mobile menu dropdown */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: rgba(251, 250, 246, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1.5px solid var(--cozy-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
    z-index: 95;
    box-shadow: 0 10px 20px rgba(21, 23, 15, 0.05);
  }

  .mobile-menu.active {
    max-height: 250px;
    opacity: 1;
  }

  .mobile-menu-container {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mobile-menu-link:hover {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest);
  }

  .mobile-menu-link.active {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest) !important;
  }

  .mobile-menu-link i {
    font-size: 1.2rem;
    color: var(--cozy-wood-sugi);
  }

  /* Content view layout spacing */
  .content-container {
    padding-top: 2rem;
  }

  /* Header chấn định */
  .family-header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
  }

  .family-page-title {
    font-size: 1.85rem;
    font-weight: 800;
    color: var(--cozy-wood-kogecha);
    margin: 0 0 0.6rem 0;
    letter-spacing: -0.2px;
  }

  .family-page-subtitle {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #555558;
    opacity: 0.85;
    margin: 0;
  }

  /* Lưới so le Pinterest Masonry chuẩn */
  .family-masonry-grid {
    column-count: 5;
    column-gap: 1.5rem;
    width: 100%;
  }

  /* Breakpoints: Mobile 2, Tablet 3, Desktop 5 */
  @media (max-width: 1023px) {
    .family-masonry-grid {
      column-count: 3;
      column-gap: 1.25rem;
    }
  }

  @media (max-width: 639px) {
    .family-masonry-grid {
      column-count: 2;
      column-gap: 0.85rem;
    }
  }

  /* Polaroid Card container */
  .polaroid-card {
    display: inline-block; /* MUST be inline-block for column-count masonry grid to prevent card half-splitting! */
    width: 100%;
    break-inside: avoid;
    margin-bottom: 1.5rem;
    cursor: pointer;
    perspective: 1000px; /* Necessary for Y-axis 3D rotation */
    position: relative;
  }

  /* Bổ sung độ nghiêng lệch ngẫu nhiên mô phỏng ảnh Polaroid thật rải rác */
  .polaroid-card:nth-child(odd) {
    transform: rotate(-1.2deg);
  }
  .polaroid-card:nth-child(even) {
    transform: rotate(1.5deg);
  }
  .polaroid-card:nth-child(3n) {
    transform: rotate(-0.8deg);
  }
  .polaroid-card:nth-child(5n) {
    transform: rotate(1.8deg);
  }

  .polaroid-card:hover {
    z-index: 50;
    transform: scale(1.04) rotate(0deg);
    transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Wrapper xoay lật 3D */
  .polaroid-card-inner {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    transition: transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Trạng thái lật mặt sau */
  .polaroid-card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  /* Thiết kế đồng bộ hai mặt */
  .card-front, .card-back {
    width: 100%;
    backface-visibility: hidden; /* Hide other side when rotated */
    border-radius: 2px; /* Real polaroids have slightly sharp/squared corners */
    box-shadow: 0 6px 14px rgba(139, 94, 60, 0.08), 0 2px 4px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.3s ease;
  }

  .polaroid-card:hover .card-front,
  .polaroid-card:hover .card-back {
    box-shadow: 0 15px 30px rgba(139, 94, 60, 0.16), 0 4px 8px rgba(0, 0, 0, 0.06);
  }

  .card-back {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    transform: rotateY(180deg); /* Pre-flip back side */
  }

  /* --- MẶT TRƯỚC: ẢNH POLAROID HOÀN HẢO --- */
  .polaroid-frame {
    background-color: #FCFCFA; /* Warm physical photo-paper color */
    padding: 0.75rem 0.75rem 2.2rem 0.75rem; /* Classic thick bottom layout */
    border: 1px solid rgba(139, 94, 60, 0.12);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* Khung bo ảnh mô phỏng khe lắp film thực tế */
  .photo-wrapper {
    width: 100%;
    overflow: hidden;
    background-color: #1A1A17; /* Dark inner backing */
    border: 1px solid rgba(0, 0, 0, 0.12);
    box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.25); /* Inner slot shadow */
    border-radius: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .polaroid-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .polaroid-caption {
    text-align: center;
    padding-top: 0.3rem;
  }

  /* Chữ viết tay tên ảnh bằng mực bút bi xanh đen */
  .caption-text {
    font-family: 'Caveat', cursive;
    font-size: 1.25rem;
    font-weight: 700;
    color: #1c2d3d; /* Classic ballpoint blue-black ink */
    letter-spacing: 0.2px;
    transform: rotate(-1.5deg);
    display: inline-block;
  }

  /* --- MẶT SAU: GIẤY NHẬT KÝ KẺ DÒNG VINTAGE --- */
  .card-back {
    background-color: #FAF6EE; /* Aged paper tone */
    border: 1px solid rgba(139, 94, 60, 0.12);
    border-radius: 2px;
  }

  .note-paper {
    width: 100%;
    height: 100%;
    padding: 0.85rem;
    display: flex;
    box-sizing: border-box;
  }

  .note-pattern {
    width: 100%;
    height: 100%;
    border: 1px dashed rgba(139, 94, 60, 0.15);
    border-radius: 1px;
    padding: 1.1rem 0.8rem 0.6rem 0.8rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
    /* Lined paper pattern: aligned to 24px vertical steps */
    background-image: linear-gradient(to bottom, transparent 23px, #E5DEC9 23px);
    background-size: 100% 24px;
    background-position: 0 8px;
  }

  .lined-content {
    flex-grow: 1;
    overflow: hidden;
  }

  /* Đồng bộ font size và line-height khớp sọc dòng kẻ nhạt phía sau */
  .note-handwritten {
    font-family: 'Caveat', cursive;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 24px; /* Matches background-size height to snap on lines! */
    color: #38302E; /* Pencil carbon shade */
    margin: 0;
    text-align: left;
    word-break: break-word;
    /* Soft handwriting spacing */
    padding-left: 0.2rem;
    letter-spacing: 0.1px;
  }

  .note-footer {
    text-align: right;
    padding-top: 0.4rem;
    border-top: 1px dashed rgba(139, 94, 60, 0.15);
  }

  .note-date {
    font-family: 'Caveat', cursive;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cozy-wood-sugi);
  }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }

  .animate-fade-in-delayed {
    animation: fadeIn 0.8s ease-out 0.2s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
