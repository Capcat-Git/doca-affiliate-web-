---
import Layout from '../layouts/Layout.astro';
import familyData from '../data/family.json';

// Tải danh sách hình ảnh gia đình từ JSON
const familyPhotos = familyData;
---

<Layout 
  title="Góc Nhỏ Gia Đình | doca.pet" 
  description="Nơi cất giữ những khoảnh khắc ấm áp và mộc mạc của gia đình nhà DOCA. Mời cô chú lật xem từng bức ảnh chụp kỷ niệm của tụi con nhé. 🐾"
>
  <main class="family-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text">Sản phẩm</a>
            <a href="/family" class="nav-link-text active">Gia đình</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/family" class="mobile-menu-link active"><i class="ph-light ph-users"></i> Gia đình</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <div class="container content-container">
      <!-- Header góc gia đình (Đồng bộ layout và font chữ giống hệt kệ trang chủ) -->
      <div class="shelf-header animate-fade-in">
        <div class="shelf-header-info">
          <h3 class="title-large shelf-title">Góc Nhỏ Gia Đình</h3>
          <span class="shelf-subtitle">mỗi bức ảnh là một lát cắt thời gian dịu êm mẹ Lin chụp cho tụi con.</span>
        </div>
      </div>

      <!-- Pinterest-style Masonry Grid -->
      <div class="family-masonry-grid">
        {familyPhotos.map((photo) => (
          <div class="polaroid-card" data-id={photo.id}>
            <div class="polaroid-card-inner">
              
              <!-- Mặt trước: Thẻ ảnh tối giản Muji (Giống card sản phẩm, không có tiêu đề tả thực) -->
              <div class="card-front">
                <div class="polaroid-frame">
                  <div class="photo-wrapper" style={`aspect-ratio: ${photo.aspectRatio || '1/1'};`}>
                    <img src={photo.imageUrl} alt={photo.title} class="polaroid-photo" loading="lazy" />
                  </div>
                  <div class="polaroid-caption">
                    <span class="caption-text">@capcat.family</span>
                  </div>
                </div>
              </div>

              <!-- Mặt sau: Ghi chú dùng Space Mono tối giản dạng nhãn mác -->
              <div class="card-back">
                <div class="note-paper">
                  <div class="note-content-wrapper">
                    <p class="note-monospace">{photo.note}</p>
                    <div class="note-footer">
                      <span class="note-tag">#family</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  // Kích hoạt tính năng click/touch để lật ảnh (3D Flip toggle) và đóng mở mobile menu
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. POLAROID CARD FLIP ---
    const cards = document.querySelectorAll('.polaroid-card');
    
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        
        const inner = card.querySelector('.polaroid-card-inner');
        if (inner) {
          inner.classList.toggle('is-flipped');
        }
      });
    });
  });
</script>

<style>
  .family-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-beige); /* Đồng bộ background trang chủ */
    padding-bottom: 5rem;
  }

  /* Navbar Styles matching product.astro & index.astro */
  .navbar {
    background-color: rgba(251, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cozy-border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 0;
    box-shadow: 0 1px 3px rgba(21, 23, 15, 0.04);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link-text:hover {
    color: var(--cozy-green-matcha-forest);
  }

  .nav-link-text.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
    transition: transform 0.3s ease;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--cozy-text-obsidian);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links-desktop {
    display: none; /* Hidden on mobile */
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none; /* Hidden on desktop */
    }
  }

  /* Mobile menu dropdown */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: rgba(251, 250, 246, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1.5px solid var(--cozy-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
    z-index: 95;
    box-shadow: 0 10px 20px rgba(21, 23, 15, 0.05);
  }

  .mobile-menu.active {
    max-height: 250px;
    opacity: 1;
  }

  .mobile-menu-container {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mobile-menu-link:hover {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest);
  }

  .mobile-menu-link.active {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest) !important;
  }

  .mobile-menu-link i {
    font-size: 1.2rem;
    color: var(--cozy-wood-sugi);
  }

  /* Content view layout spacing */
  .content-container {
    padding-top: 2rem;
  }

  /* Header đồng bộ 100% giống trang chủ */
  .shelf-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 3rem;
    text-align: center;
  }

  .shelf-header-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }

  .shelf-title {
    font-family: 'Inter', sans-serif;
    font-size: 1.45rem;
    font-weight: 750;
    color: var(--cozy-wood-kogecha);
    margin: 0;
  }

  .shelf-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-green-matcha-forest);
    letter-spacing: 0.2px;
  }

  /* Lưới so le Pinterest Masonry chuẩn */
  .family-masonry-grid {
    column-count: 5;
    column-gap: 1.5rem;
    width: 100%;
  }

  /* Breakpoints: Mobile 2, Tablet 3, Desktop 5 */
  @media (max-width: 1023px) {
    .family-masonry-grid {
      column-count: 3;
      column-gap: 1.25rem;
    }
  }

  @media (max-width: 639px) {
    .family-masonry-grid {
      column-count: 2;
      column-gap: 0.85rem;
    }
  }

  /* Polaroid Card container */
  .polaroid-card {
    display: inline-block;
    width: 100%;
    break-inside: avoid;
    margin-bottom: 1.5rem;
    cursor: pointer;
    perspective: 1000px;
    position: relative;
  }

  /* Muji Zen: Nghiêng rất khẽ mô phỏng trải thẻ tự nhiên */
  .polaroid-card:nth-child(odd) {
    transform: rotate(-0.5deg);
  }
  .polaroid-card:nth-child(even) {
    transform: rotate(0.6deg);
  }
  .polaroid-card:nth-child(3n) {
    transform: rotate(-0.3deg);
  }
  .polaroid-card:nth-child(5n) {
    transform: rotate(0.8deg);
  }

  .polaroid-card:hover {
    z-index: 50;
    transform: scale(1.035) rotate(0deg);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Wrapper xoay lật 3D */
  .polaroid-card-inner {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    transition: transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Trạng thái lật mặt sau */
  .polaroid-card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  /* Thiết kế đồng bộ hai mặt giống card sản phẩm */
  .card-front, .card-back {
    width: 100%;
    backface-visibility: hidden;
    border-radius: 18px; /* Đồng bộ bo góc card sản phẩm */
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.01);
    transition: box-shadow 0.3s ease;
  }

  .polaroid-card:hover .card-front,
  .polaroid-card:hover .card-back {
    box-shadow: 0 8px 20px rgba(139, 94, 60, 0.08);
  }

  .card-back {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    transform: rotateY(180deg);
  }

  /* --- MẶT TRƯỚC: CARD ẢNH CỦA GIA ĐÌNH (GIỐNG CARD SẢN PHẨM) --- */
  .polaroid-frame {
    background-color: var(--cozy-bg-pure);
    padding: 0.65rem;
    border: 1px solid var(--cozy-border-light);
    border-radius: 18px;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    height: 100%;
  }

  /* Khung bo ảnh giống hệt card sản phẩm */
  .photo-wrapper {
    width: 100%;
    overflow: hidden;
    background-color: var(--cozy-bg-beige);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .polaroid-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .polaroid-caption {
    text-align: center;
    padding: 0.25rem 0;
  }

  /* Nhãn @capcat.family bằng Space Mono nhỏ xíu tinh tế */
  .caption-text {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--cozy-wood-sugi);
    letter-spacing: 0.5px;
    display: inline-block;
  }

  /* --- MẶT SAU: LỜI NHẮN MÓN ĐỒ VỚI SPACE MONO TỐI GIẢN (MUJI) --- */
  .card-back {
    background-color: var(--cozy-bg-pure);
    border: 1px solid var(--cozy-border-light);
    border-radius: 18px;
  }

  .note-paper {
    width: 100%;
    height: 100%;
    padding: 1.25rem;
    display: flex;
    box-sizing: border-box;
  }

  .note-content-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
  }

  /* Chữ viết bằng Space Mono, không còn dòng kẻ tả thực */
  .note-handwritten {
    font-family: 'Space Mono', monospace;
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--cozy-text-obsidian);
    margin: 0;
    text-align: left;
    word-break: break-word;
  }

  .note-footer {
    text-align: right;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--cozy-border-light);
  }

  .note-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--cozy-wood-sugi);
  }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }

  .animate-fade-in-delayed {
    animation: fadeIn 0.8s ease-out 0.2s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
