---
import Layout from '../layouts/Layout.astro';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';
---

<Layout title="Giới Thiệu Dự Án App DOCA | Sống Chậm Cùng Thú Cưng" description="Khám phá triết lý chữa lành (Iyashikei) của ứng dụng DOCA và đăng ký nhận slot trải nghiệm bản Beta sớm dành riêng cho Sen và Boss.">
  <script is:inline define:vars={{ supabaseUrl, supabaseKey }}>
    window.PUBLIC_SUPABASE_URL = supabaseUrl;
    window.PUBLIC_SUPABASE_ANON_KEY = supabaseKey;
  </script>

  <main class="about-view">
    <div class="container">
      <a href="/" class="back-link"><i class="ph-light ph-arrow-left"></i> Trở về trang chủ</a>

      <header class="about-header text-center">
        <span class="about-icon" style="color: var(--cozy-pink-sakura);"><i class="ph-light ph-sparkles"></i></span>
        <h1 class="display-large">Về Doca — Góc Nhỏ Bình Yên</h1>
        <p class="whisper-mono">"Nơi những tâm hồn bận rộn dừng chân, và Boss cưng lên tiếng..."</p>
      </header>

      <section class="about-manifesto-section">
        <div class="manifesto-grid">
          <div class="manifesto-image-wrapper">
            <img src="/images/about-illustration.png" alt="Góc bình yên cùng Boss" class="manifesto-image" />
          </div>
          <div class="about-manifesto cozy-card">
            <h2 class="title-large">Thư gửi Sen từ mái nhà Doca 🐾</h2>
            <p>
              Chúng mình xây dựng <strong>DOCA</strong> không phải để tạo ra một chiếc app ghi chép số liệu cân nặng hay lịch tiêm phòng khô khan. Giữa lòng thành phố chật chội và vội vã này, tụi mình muốn tạo nên một góc trú ẩn nhỏ — một mái nhà ấm áp nơi những người đô thị cô đơn tìm thấy sự xoa dịu.
            </p>
            <p>
              Đối với thú cưng, bạn không cần nhà lầu, xe hơi, hay chức danh quản lý vĩ đại ngoài xã hội. Bạn chỉ cần gãi cằm cho bé, cùng chải lông dưới nắng chiều hoàng hôn, hay bình thường hóa sự chờ đợi của Boss khi bạn đi làm — đó không phải là bi kịch cô đơn, mà là sự tích lũy tình thương ngọt ngào khi bé ôm chiếc giày cũ của bạn để hít hà mùi hương quen thuộc.
            </p>
            <p>
              Lấy cảm hứng từ triết lý tối giản của MUJI và sự tĩnh lặng của những chiều thu Nhật Bản (Iyashikei), DOCA không có quảng cáo ồn ã, không có thông báo hối hả. Chỉ có bạn, tiếng gừ gừ êm ái của bé mèo, và một khoảng không yên ả để cùng nhau chậm lại, chữa lành sự kiệt sức đô thị (Urban Burnout) sau một ngày dài...
            </p>
          </div>
        </div>
      </section>

      <section class="features-preview">
        <h2 class="title-large text-center section-title">Bốn Góc Nhỏ Trong Ngôi Nhà Doca</h2>
        
        <div class="features-grid">
          <div class="cozy-card feature-item">
            <span class="feature-icon"><i class="ph-light ph-users"></i></span>
            <h3>PetTwin — Linh Hồn Bé Nhỏ</h3>
            <p>Biến tính cách ngoài đời của Boss (Ngáo ngơ, Chảnh chọe, Đanh đá, Nịnh nọt) thành giọng nói AI ấm áp. Sen sẽ được nghe Boss cằn nhằn hay nịnh nọt dưới góc nhìn ngộ nghĩnh của riêng bé.</p>
          </div>

          <div class="cozy-card feature-item">
            <span class="feature-icon"><i class="ph-light ph-package"></i></span>
            <h3>Capsule — Chiếc Rương Ký Ức</h3>
            <p>Nơi cất giữ những bức ảnh dìm hàng, những khoảnh khắc vụn vặt và những câu chuyện chỉ hai đứa biết. Boss ảo sẽ khắc ghi những kỷ niệm này sâu sắc vào tim để trò chuyện cùng Sen sau này.</p>
          </div>

          <div class="cozy-card feature-item">
            <span class="feature-icon"><i class="ph-light ph-chat-circle"></i></span>
            <h3>Trò Chuyện Tri Kỷ</h3>
            <p>Kênh trò chuyện không giới hạn, không phán xét. Đôi khi chỉ là vài câu đối thoại ngây ngô từ Boss cưng cũng đủ quét đi mọi mây mù trong lòng bạn.</p>
          </div>

          <div class="cozy-card feature-item">
            <span class="feature-icon"><i class="ph-light ph-mailbox"></i></span>
            <h3>Hòm Thư Nhỏ Namiya</h3>
            <p>Góc khuất yên ả nơi bạn trút bỏ những tâm sự thầm kín vào chiếc hòm gỗ. Ông già Namiya và 3 chú mèo nhỏ sẽ luôn lắng nghe và phản hồi xoa dịu bạn trước khi bình minh lên.</p>
          </div>
        </div>
      </section>

      <!-- Form đăng ký Waitlist -->
      <section class="waitlist-card cozy-card text-center">
        <span class="waitlist-icon"><i class="ph-light ph-envelope-simple"></i></span>
        <h2 class="title-large">Sen muốn nhận thư từ Boss không?</h2>
        <p class="waitlist-desc">
          Hãy để lại email tại đây nhé. Boss sẽ gửi tặng Sen cuốn Ebook <strong>"Nhật Ký Sống Chậm Cùng Boss (Cẩm nang 7 ngày chánh niệm)"</strong> bản PDF và một chiếc vé mời trải nghiệm sớm bản Beta khi app ra mắt.
        </p>

        <form id="about-waitlist-form" class="waitlist-form" novalidate>
          <input 
            type="email" 
            id="waitlist-email" 
            class="form-input" 
            placeholder="Nhập email của Sen tại đây..." 
            required 
          />
          <button type="submit" class="cozy-btn cozy-btn-primary submit-btn">
            Nhận Quà Từ Boss <i class="ph-light ph-gift"></i>
          </button>
        </form>

        <!-- Custom Friendly Error Notification -->
        <div id="about-error-msg" class="about-error-msg hidden">
          <i class="ph-light ph-warning-circle error-icon"></i>
          <span id="about-error-text">Hình như email của Sen bị thiếu ký tự '@' hoặc sai định dạng rồi... Nhập lại giúp tụi con nha! 🐾</span>
        </div>

        <div id="waitlist-success" class="waitlist-success hidden">
          <span class="success-paw" style="color: var(--cozy-green-matcha);"><i class="ph-light ph-paw"></i></span>
          <h4>Boss đã nhận được thư của Sen!</h4>
          <p>Ebook quà tặng đang trên đường bay tới hòm thư của bạn. Sen nhớ kiểm tra cả hộp thư Spam/Quảng cáo nhé!</p>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .about-view {
    padding-top: 3rem;
    padding-bottom: 5rem;
    background-color: var(--cozy-bg-beige);
  }

  .text-center {
    text-align: center;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 2rem;
    transition: transform 0.2s ease;
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  .about-header {
    margin-bottom: 3rem;
  }

  .about-icon {
    font-size: 2.5rem;
  }

  .manifesto-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 768px) {
    .manifesto-grid {
      grid-template-columns: 1fr 1.25fr;
      align-items: center;
      gap: 2rem;
    }
  }

  .manifesto-image-wrapper {
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 2px solid var(--cozy-wood-sugi);
    box-shadow: var(--cozy-shadow-default);
    aspect-ratio: 1.05;
  }

  .manifesto-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .manifesto-image-wrapper:hover .manifesto-image {
    transform: scale(1.04);
  }

  .about-manifesto {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 4px solid var(--cozy-green-matcha);
  }

  .about-manifesto p {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--cozy-text-obsidian);
  }

  .features-preview {
    margin-bottom: 4rem;
  }

  .section-title {
    margin-bottom: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 540px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-icon {
    font-size: 1.75rem;
    color: var(--cozy-green-matcha);
    display: inline-block;
  }

  .feature-item h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .feature-item p {
    font-size: 0.9rem;
    color: #6E6E73;
    line-height: 1.5;
  }

  /* Waitlist Card */
  .waitlist-card {
    background-color: var(--cozy-bg-pure);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2.5rem 2rem;
    border: 1px solid var(--cozy-border-light);
  }

  .waitlist-icon {
    font-size: 2rem;
    color: var(--cozy-pink-sakura);
    display: inline-block;
  }

  .waitlist-desc {
    font-size: 0.95rem;
    color: #6E6E73;
    max-width: 480px;
    line-height: 1.6;
  }

  .waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 400px;
    margin-top: 0.5rem;
  }

  @media (min-width: 480px) {
    .waitlist-form {
      flex-direction: row;
    }
    .waitlist-form .form-input {
      flex-grow: 1;
    }
  }

  .form-input {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    padding: 0.75rem;
    border-radius: var(--radius-button);
    border: 1px solid var(--cozy-border-light);
    background-color: var(--cozy-bg-oatmeal);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-input:focus {
    border-color: var(--cozy-green-matcha);
  }

  .submit-btn {
    white-space: nowrap;
  }

  /* Waitlist Success */
  .waitlist-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0;
    animation: fadeIn 0.5s ease;
  }

  .waitlist-success.hidden {
    display: none;
  }

  .success-paw {
    font-size: 2rem;
    animation: bounce 1s infinite alternate;
  }

  .waitlist-success h4 {
    font-family: 'Inter', sans-serif;
    font-size: 1.25rem;
    color: var(--cozy-text-obsidian);
    font-weight: 700;
  }

  .waitlist-success p {
    font-size: 0.9rem;
    color: #6E6E73;
    max-width: 320px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    from { transform: translateY(0); }
    to { transform: translateY(-6px); }
  }

  .about-error-msg {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background-color: #FFF2E6; /* Cozy soft orange tint */
    border: 1px solid rgba(230, 100, 0, 0.15);
    color: #CC5200; /* Darker burnt orange for high contrast */
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 12px;
    margin: 0.75rem auto 0 auto;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 4px 12px rgba(230, 100, 0, 0.04);
    animation: fadeIn 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .about-error-msg.hidden {
    display: none;
  }

  .error-icon {
    font-size: 1.15rem;
    color: #CC5200;
    flex-shrink: 0;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('about-waitlist-form') as HTMLFormElement;
    const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
    const successMsg = document.getElementById('waitlist-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const errorMsg = document.getElementById('about-error-msg');
      const errorText = document.getElementById('about-error-text');
      if (errorMsg) errorMsg.classList.add('hidden');

      const email = emailInput.value.trim();

      if (!email) {
        if (errorMsg && errorText) {
          errorText.textContent = "Hình như Sen chưa điền email kìa... Nhập email để tụi con gửi quà nhé! 🐾";
          errorMsg.classList.remove('hidden');
        }
        return;
      }

      // Simple email validation regex
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        if (errorMsg && errorText) {
          errorText.textContent = "Hình như email của Sen bị thiếu ký tự '@' hoặc sai định dạng rồi... Nhập lại giúp tụi con nha! 🐾";
          errorMsg.classList.remove('hidden');
        }
        return;
      }

      const supabaseUrl = (window as any).PUBLIC_SUPABASE_URL || '';
      const supabaseKey = (window as any).PUBLIC_SUPABASE_ANON_KEY || '';

      if (supabaseUrl && supabaseKey) {
        try {
          const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
          if (submitBtn) submitBtn.disabled = true;

          const res = await fetch(`${supabaseUrl}/rest/v1/waitlist`, {
            method: 'POST',
            headers: {
              'apikey': supabaseKey,
              'Authorization': `Bearer ${supabaseKey}`,
              'Content-Type': 'application/json',
              'Prefer': 'return=minimal'
            },
            body: JSON.stringify({
              email: email,
              source_channel: 'about_waitlist'
            })
          });

          if (res.ok) {
            if (typeof (window as any).gtag === 'function') {
              (window as any).gtag('event', 'join_waitlist', {
                email: email,
                source_channel: 'about_waitlist'
              });
            }
            form.style.display = 'none';
            successMsg?.classList.remove('hidden');
          } else {
            if (errorMsg && errorText) {
              errorText.textContent = "Có lỗi xảy ra khi đăng ký waitlist, Sen vui lòng thử lại nhé! 🐾";
              errorMsg.classList.remove('hidden');
            }
            if (submitBtn) submitBtn.disabled = false;
          }
        } catch (err) {
          console.error(err);
          if (errorMsg && errorText) {
            errorText.textContent = "Không thể kết nối máy chủ. Sen hãy kiểm tra mạng nhé! 🐾";
            errorMsg.classList.remove('hidden');
          }
          const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
          if (submitBtn) submitBtn.disabled = false;
        }
      } else {
        console.warn('Supabase credentials missing. Simulating waitlist signup.');
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'join_waitlist', {
            email: email,
            source_channel: 'about_waitlist'
          });
        }
        form.style.display = 'none';
        successMsg?.classList.remove('hidden');
      }
    });
  });
</script>
