---
import Layout from '../layouts/Layout.astro';
import familyData from '../data/family.json';

// Tải danh sách hình ảnh gia đình từ JSON
const familyPhotos = familyData;
---

<Layout 
  title="Góc Nhỏ Gia Đình | doca.pet" 
  description="Nơi cất giữ những khoảnh khắc ấm áp và mộc mạc của gia đình nhà DOCA. Mời cô chú lật xem từng bức ảnh chụp kỷ niệm của tụi con nhé. 🐾"
>
  <main class="family-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text">Sản phẩm</a>
            <a href="/family" class="nav-link-text active">Gia đình</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/family" class="mobile-menu-link active"><i class="ph-light ph-users"></i> Gia đình</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <div class="container content-container">
      <!-- Header góc gia đình (Đồng bộ kiểu dáng và phông chữ giống hình minh họa) -->
      <div class="family-header animate-fade-in">
        <span class="family-tag">GÓC NHỎ DOCA</span>
        <h1 class="family-page-title">Góc Nhỏ Gia Đình</h1>
        <p class="family-page-subtitle animate-fade-in-delayed">
          mỗi bức ảnh là một lát cắt thời gian dịu êm mẹ Lin chụp cho tụi con...<br />
          cô chú nhấp nhẹ vào từng tấm ảnh để đọc những dòng nhật ký viết tay ở mặt sau nhé. 🐾
        </p>
      </div>

      <!-- Pinterest-style Masonry Grid (Khoảng cách mỏng hơn cho hình to ra) -->
      <div class="family-masonry-grid">
        {familyPhotos.map((photo) => (
          <div class="polaroid-card" data-id={photo.id}>
            <div class="polaroid-card-inner">
              
              <!-- Mặt trước: Thẻ ảnh Muji viền mỏng bo nhọn, watermark trên hình, chân hình trống -->
              <div class="card-front">
                <div class="polaroid-frame">
                  <div class="photo-wrapper" style={`aspect-ratio: ${photo.aspectRatio || '1/1'};`}>
                    <img src={photo.imageUrl} alt={photo.title} class="polaroid-photo" loading="lazy" />
                    <span class="photo-watermark">@capcat.family</span>
                  </div>
                  <!-- Chân hình bỏ trống không có chữ -->
                </div>
              </div>

              <!-- Mặt sau: Ghi chú dùng Space Mono tối giản, viền mỏng bo nhọn -->
              <div class="card-back">
                <div class="note-paper">
                  <div class="note-content-wrapper">
                    <p class="note-monospace">{photo.note}</p>
                    <div class="note-footer">
                      <span class="note-tag">#family</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  // Kích hoạt tính năng click/touch để lật ảnh (3D Flip toggle) và đóng mở mobile menu
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. POLAROID CARD FLIP (Chỉ cho phép duy nhất một card lật tại một thời điểm) ---
    const cards = document.querySelectorAll('.polaroid-card');
    
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        
        const inner = card.querySelector('.polaroid-card-inner');
        if (inner) {
          const isFlipped = inner.classList.contains('is-flipped');
          
          // Xoay ngược tất cả các card khác đang bị lật về trạng thái cũ
          document.querySelectorAll('.polaroid-card-inner.is-flipped').forEach(flippedInner => {
            if (flippedInner !== inner) {
              flippedInner.classList.remove('is-flipped');
            }
          });
          
          // Lật hoặc trả card hiện tại
          inner.classList.toggle('is-flipped');
        }
      });
    });
  });
</script>

<style>
  .family-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-beige); /* Đồng bộ background trang chủ */
    padding-bottom: 5rem;
  }

  /* Navbar Styles matching product.astro & index.astro */
  .navbar {
    background-color: rgba(251, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cozy-border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 0;
    box-shadow: 0 1px 3px rgba(21, 23, 15, 0.04);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link-text:hover {
    color: var(--cozy-green-matcha-forest);
  }

  .nav-link-text.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
    transition: transform 0.3s ease;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--cozy-text-obsidian);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links-desktop {
    display: none; /* Hidden on mobile */
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none; /* Hidden on desktop */
    }
  }

  /* Mobile menu dropdown */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: rgba(251, 250, 246, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1.5px solid var(--cozy-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
    z-index: 95;
    box-shadow: 0 10px 20px rgba(21, 23, 15, 0.05);
  }

  .mobile-menu.active {
    max-height: 250px;
    opacity: 1;
  }

  .mobile-menu-container {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mobile-menu-link:hover {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest);
  }

  .mobile-menu-link.active {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest) !important;
  }

  .mobile-menu-link i {
    font-size: 1.2rem;
    color: var(--cozy-wood-sugi);
  }

  /* Content view layout spacing */
  .content-container {
    padding-top: 2rem;
  }

  /* Header đồng bộ thiết kế hình ảnh minh họa */
  .family-header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
  }

  .family-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2px;
    color: #E05F65; /* Màu đỏ hồng giống header trang chủ */
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.6rem;
  }

  .family-page-title {
    font-family: 'Inter', sans-serif;
    font-size: 2rem; /* Chữ to đậm nét như hình minh họa */
    font-weight: 800;
    color: var(--cozy-text-obsidian);
    margin: 0 0 1rem 0;
    letter-spacing: -0.5px;
  }

  .family-page-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    line-height: 1.65;
    color: #6E6A60;
    opacity: 0.95;
    margin: 0;
  }

  /* Lưới so le Pinterest Masonry chuẩn (Gap mỏng lại để hình to ra) */
  .family-masonry-grid {
    column-count: 5;
    column-gap: 0.65rem;
    width: 100%;
  }

  /* Breakpoints: Mobile 2, Tablet 3, Desktop 5 */
  @media (max-width: 1023px) {
    .family-masonry-grid {
      column-count: 3;
      column-gap: 0.5rem;
    }
  }

  @media (max-width: 639px) {
    .family-masonry-grid {
      column-count: 2;
      column-gap: 0.4rem;
    }
  }

  /* Polaroid Card container (Card KHÔNG nghiêng) */
  .polaroid-card {
    display: inline-block;
    width: 100%;
    break-inside: avoid;
    margin-bottom: 0.65rem;
    cursor: pointer;
    perspective: 1000px;
    position: relative;
    transform: none !important; /* Đảm bảo phẳng hoàn toàn không nghiêng */
  }

  @media (max-width: 1023px) {
    .polaroid-card {
      margin-bottom: 0.5rem;
    }
  }

  @media (max-width: 639px) {
    .polaroid-card {
      margin-bottom: 0.4rem;
    }
  }

  .polaroid-card:hover {
    z-index: 50;
    transform: scale(1.035) !important; /* Chỉ phóng to khẽ, giữ hướng thẳng đứng */
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Wrapper xoay lật 3D */
  .polaroid-card-inner {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    transition: transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Trạng thái lật mặt sau */
  .polaroid-card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  /* Thiết kế viền siêu mỏng và bo nhọn hơn (radius 4px) */
  .card-front, .card-back {
    width: 100%;
    backface-visibility: hidden;
    border-radius: 4px;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.02);
    transition: box-shadow 0.3s ease;
  }

  .polaroid-card:hover .card-front,
  .polaroid-card:hover .card-back {
    box-shadow: 0 6px 15px rgba(139, 94, 60, 0.06);
  }

  .card-back {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    transform: rotateY(180deg);
  }

  /* --- MẶT TRƯỚC: CARD ẢNH POLAROID VIỀN MỎNG --- */
  .polaroid-frame {
    background-color: var(--cozy-bg-pure);
    padding: 0.5rem 0.5rem 1.75rem 0.5rem; /* Chân hình để trống hoàn toàn */
    border: 0.5px solid rgba(139, 94, 60, 0.15); /* Viền siêu mỏng */
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  /* Khung ảnh tối giản, không mô phỏng tả thực */
  .photo-wrapper {
    width: 100%;
    overflow: hidden;
    background-color: var(--cozy-bg-beige);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .polaroid-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  /* Watermark nhỏ xíu trên hình ảnh */
  .photo-watermark {
    position: absolute;
    bottom: 8px;
    right: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    font-weight: 700;
    color: #FFFFFF;
    opacity: 0.45;
    letter-spacing: 0.5px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
    pointer-events: none;
    z-index: 10;
  }

  /* --- MẶT SAU: LỜI NHẮN VỚI SPACE MONO TỐI GIẢN --- */
  .card-back {
    background-color: var(--cozy-bg-pure);
    border: 0.5px solid rgba(139, 94, 60, 0.15);
    border-radius: 4px;
  }

  .note-paper {
    width: 100%;
    height: 100%;
    padding: 1.15rem;
    display: flex;
    box-sizing: border-box;
  }

  .note-content-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
  }

  .note-handwritten {
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.6;
    color: var(--cozy-text-obsidian);
    margin: 0;
    text-align: left;
    word-break: break-word;
  }

  .note-footer {
    text-align: right;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--cozy-border-light);
  }

  .note-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--cozy-wood-sugi);
  }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }

  .animate-fade-in-delayed {
    animation: fadeIn 0.8s ease-out 0.2s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
