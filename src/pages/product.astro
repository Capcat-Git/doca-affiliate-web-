if (products.length === 0) {
  products = STATIC_PRODUCTS_FALLBACK;
}

// Hàm format danh mục sản phẩm sang nhãn hiển thị
const getCategoryLabel = (cat: string) => {
  const labels: Record<string, string> = {
    'thuc_an': 'Thức Ăn Mèo',
    'vat_pham': 'Vật Phẩm Chăm Sóc',
    'sach': 'Sách Chữa Lành',
    'phu_kien': 'Phụ Kiện Nhà Ở'
  };
  return labels[cat] || cat;
};
---

<Layout title="Kệ quà của mẹ | doca.pet" description="Những thức quả lành tính mẹ Lin chọn cho tụi con, đong đầy yêu thương. Mời cô chú ghé lựa thong thả ạ. 🐾">
  <script is:inline define:vars={{ supabaseUrl, supabaseKey }}>
    window.PUBLIC_SUPABASE_URL = supabaseUrl;
    window.PUBLIC_SUPABASE_ANON_KEY = supabaseKey;
  </script>

  <main class="product-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text active">Sản phẩm</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link active"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <!-- Curated Shelf section -->
    <section class="shelf-section single-page-shelf">
      <div class="container">
        <div class="shelf-header">
          <div class="shelf-header-illustration-wrapper">
            <img src="/images/pet-food-bags.png" alt="Kệ quà của mẹ" class="shelf-header-illustration" />
          </div>
          <div class="shelf-header-info">
            <h3 class="title-large shelf-title">Kệ quà của mẹ</h3>
            <span class="shelf-subtitle">Thức quả lành tính mẹ Lin chọn cho tụi con.</span>
          </div>
        </div>

        <!-- Các tab phân loại (Catalogue Tabs) -->
        <div class="category-tabs-container">
          <button class="tab-btn active" data-category="all">
            <i class="ph-light ph-circles-four tab-icon-ph"></i> Tất cả
          </button>
          <button class="tab-btn" data-category="thuc_an">
            <img src="/images/pate-cans.png" class="tab-icon" alt="" /> Thức Ăn Mèo
          </button>
          <button class="tab-btn" data-category="vat_pham">
            <img src="/images/pate-dog.png" class="tab-icon" alt="" /> Vật Phẩm Chăm Sóc
          </button>
          <button class="tab-btn" data-category="sach">
            <img src="/images/clay-book.png" class="tab-icon" alt="" /> Sách Chữa Lành
          </button>
          <button class="tab-btn" data-category="phu_kien">
            <img src="/images/pet-bowls.png" class="tab-icon" alt="" /> Phụ Kiện Nhà Ở
          </button>
        </div>
        
        <div class="products-grid">
          {products.map(product => (
            <ProductCard 
              id={product.id}
              slug={product.slug}
              name={product.name}
              category={getCategoryLabel(product.category)}
              categoryRaw={product.category}
              price={product.price}
              wholesalePrice={product.wholesale_price}
              minGroupSize={product.min_group_size}
              affiliateUrl={product.affiliate_url}
              imageUrl={product.image_url}
              quote={product.quote}
            />
          ))}
        </div>

        <!-- Phân trang sản phẩm (Pagination) -->
        <div id="products-pagination" class="products-pagination"></div>

        <!-- Description at bottom -->
        <p class="shelf-desc-bottom">
          Từng lon pate sánh mịn, hạt giòn rụm cho tới chiếc lược gỡ rối... đều là những món quà lành tính đong đầy yêu thương mẹ Lin chuẩn bị cho tụi con. Cô chú cứ thong thả ghé lựa nha, tụi con ăn thấy ưng bụng lắm đó! 🐾
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Standalone Product Page styling matching homepage */
  .product-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-beige); /* Match shelf section background for unified page flow */
    padding-bottom: 4rem;
  }

  .nav-link-text.active,
  .mobile-menu-link.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  /* Navbar Styles matching index.astro */
  .navbar {
    background-color: rgba(251, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cozy-border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 0;
    box-shadow: 0 1px 3px rgba(21, 23, 15, 0.04);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link-text:hover {
    color: var(--cozy-green-matcha-forest);
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
    transition: transform 0.3s ease;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--cozy-text-obsidian);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links-desktop {
    display: none; /* Hidden on mobile */
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none; /* Hidden on desktop */
    }
  }

  /* Mobile menu dropdown */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: rgba(251, 250, 246, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1.5px solid var(--cozy-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
    z-index: 95;
    box-shadow: 0 10px 20px rgba(21, 23, 15, 0.05);
  }

  .mobile-menu.active {
    max-height: 250px;
    opacity: 1;
  }

  .mobile-menu-container {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mobile-menu-link:hover {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest);
  }

  .mobile-menu-link i {
    font-size: 1.2rem;
    color: var(--cozy-wood-sugi);
  }

  /* Curated Shelf Styles copied from index.astro to ensure identical aesthetics */
  .shelf-section {
    background-color: var(--cozy-bg-beige);
    padding: 1.5rem 0 3.5rem 0;
  }

  .single-page-shelf {
    padding-top: 1.5rem; /* Shrunk padding below sticky navbar */
  }

  .shelf-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
    border-bottom: 1px dashed var(--cozy-border-light);
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .shelf-header-illustration-wrapper {
    width: 80px;
    height: 80px;
    background-color: #FFFFFF;
    border: 2px solid var(--cozy-wood-sugi);
    border-radius: 12px;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(139, 94, 60, 0.06);
    flex-shrink: 0;
    transform: rotate(-3deg);
  }

  .shelf-header-illustration {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 8px;
  }

  .shelf-header-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .shelf-title {
    font-size: 1.45rem;
    font-weight: 750;
    color: var(--cozy-wood-kogecha);
    margin: 0;
  }

  .shelf-subtitle {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-green-matcha-forest);
    letter-spacing: 0.2px;
  }

  .shelf-desc-bottom {
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    color: #555558;
    text-align: center;
    line-height: 1.55;
    margin-top: 2rem;
    border-top: 1px dashed var(--cozy-border-light);
    padding-top: 1.5rem;
  }

  /* Grid Sản Phẩm */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(5, 1fr);
      gap: 1rem;
    }
  }

  /* Catalogue Tabs & Pagination */
  .category-tabs-container {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.65rem;
    margin-bottom: 1.25rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-left: 0.25rem;
  }
  
  .category-tabs-container::-webkit-scrollbar {
    display: none;
  }
  
  .tab-btn {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    color: #5D5E56;
    background-color: var(--cozy-bg-pure);
    border: 1px solid var(--cozy-border-light);
    padding: 0.45rem 0.95rem;
    border-radius: 20px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  
  .tab-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 4px rgba(139, 94, 60, 0.1));
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .tab-btn:hover .tab-icon {
    transform: scale(1.15) rotate(4deg);
  }

  .tab-icon-ph {
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .tab-btn:hover .tab-icon-ph {
    transform: scale(1.15);
  }
  
  .tab-btn:hover {
    background-color: var(--cozy-bg-oatmeal);
    border-color: var(--cozy-border-light);
    color: var(--cozy-text-obsidian);
  }
  
  .tab-btn.active {
    background-color: var(--cozy-green-matcha-forest);
    border-color: var(--cozy-green-matcha-forest);
    color: var(--cozy-bg-pure);
    box-shadow: 0 4px 10px rgba(74, 138, 46, 0.25);
  }

  .tab-btn.active .tab-icon {
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.15));
  }

  .products-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  :global(.page-btn) {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(74, 138, 46, 0.15);
    background-color: #E2ECD2;
    color: var(--cozy-green-matcha-dark);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.page-btn:hover:not(:disabled)) {
    background-color: var(--cozy-green-matcha);
    color: var(--cozy-bg-pure);
    border-color: var(--cozy-green-matcha);
    transform: scale(1.08);
  }

  :global(.page-btn:disabled) {
    opacity: 0.35;
    cursor: not-allowed;
    background-color: #F0F4E8;
    color: #9CADA2;
    border-color: rgba(0, 0, 0, 0.02);
  }

  :global(.page-btn.active) {
    background-color: var(--cozy-green-matcha-forest);
    color: var(--cozy-bg-pure);
    border-color: var(--cozy-green-matcha-forest);
    box-shadow: 0 4px 10px rgba(74, 138, 46, 0.25);
  }
</style>

<script>
  // Client-side interactions for tabs, pagination, and menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. CATALOGUE FILTER & PAGINATION ---
    const tabBtns = document.querySelectorAll('.category-tabs-container .tab-btn');
    const productGrid = document.querySelector('.products-grid');
    const productCards = productGrid ? productGrid.children : [];
    const paginationContainer = document.getElementById('products-pagination');
    
    let currentCategory = 'all';
    let currentPage = 1;
    const itemsPerPage = 10;
    
    function updateGrid() {
      if (!productCards.length) return;

      const filteredCards = Array.from(productCards).filter(card => {
        const cardInner = card.classList.contains('product-card-v2') ? card : card.querySelector('.product-card-v2');
        if (!cardInner) return false;
        const categoryRaw = cardInner.getAttribute('data-category-raw') || '';
        if (currentCategory === 'all') return true;
        return categoryRaw === currentCategory;
      });
      
      const totalItems = filteredCards.length;
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      
      if (currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
      
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      
      // Hide all first
      Array.from(productCards).forEach(card => {
        (card as HTMLElement).style.display = 'none';
      });
      
      // Show filtered page items
      filteredCards.forEach((card, index) => {
        if (index >= startIndex && index < endIndex) {
          (card as HTMLElement).style.display = 'block';
        }
      });
      
      // Render pagination
      renderPagination(totalPages);
    }
    
    function renderPagination(totalPages: number) {
      if (!paginationContainer) return;
      
      if (totalPages <= 1) {
        paginationContainer.innerHTML = '';
        paginationContainer.style.display = 'none';
        return;
      }
      
      paginationContainer.style.display = 'flex';
      let html = '';
      
      // Prev
      html += `<button class="page-btn prev-btn" ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}"><i class="ph-light ph-caret-left"></i></button>`;
      
      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        html += `<button class="page-btn num-btn ${currentPage === i ? 'active' : ''}" data-page="${i}">${i}</button>`;
      }
      
      // Next
      html += `<button class="page-btn next-btn" ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}"><i class="ph-light ph-caret-right"></i></button>`;
      
      paginationContainer.innerHTML = html;
      
      // Events
      paginationContainer.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          if (target.disabled) return;
          const pageNum = parseInt(target.getAttribute('data-page') || '1');
          currentPage = pageNum;
          updateGrid();
          
          const shelfSection = document.querySelector('.shelf-section');
          shelfSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }
    
    // Tab event handlers
    tabBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        tabBtns.forEach(b => b.classList.remove('active'));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add('active');
        
        currentCategory = target.getAttribute('data-category') || 'all';
        currentPage = 1;
        updateGrid();
      });
    });
    
    // Initial run
    updateGrid();
  });
</script>
