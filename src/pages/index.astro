<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- HAMBURGER MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    mobileMenuLinks.forEach(link => {
      link.addEventListener('click', () => {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 1. COZY MUSIC PLAYER HANDLER (DOCA FM RADIO SYNCED) ---
    const audio = document.getElementById('cozy-audio-player') as HTMLAudioElement;
    const playBtn = document.querySelector('.player-control-btn');
    const playerContainer = document.querySelector('.cozy-music-player');
    const playerTitle = document.querySelector('.player-title');
    const playerStatus = document.querySelector('.player-status');
    const spotifyLink = document.querySelector('.player-spotify-link');
    const playIcon = document.querySelector('.play-icon');
    const pauseIcon = document.querySelector('.pause-icon');

    // FM Playlist (1940s Vintage Cafe Jazz BGM)
    const fmPlaylist = [
      {
        title: "Moonlight Serenade (1939) 🎷",
        src: "https://archive.org/download/giants-of-jazz-glen-miller/Side%20One%20-%2001%20-%20Moonlight%20Serenade.mp3",
        duration: 204,
        spotifyUrl: "https://open.spotify.com/playlist/37i9dQZF1DX8Uebhn2wRmS"
      },
      {
        title: "In the Mood (1939) 🎺",
        src: "https://archive.org/download/giants-of-jazz-glen-miller/Side%20Two%20-%2001%20-%20In%20the%20Mood.mp3",
        duration: 216,
        spotifyUrl: "https://open.spotify.com/playlist/37i9dQZF1DX8Uebhn2wRmS"
      }
    ];

    const totalPlaylistDuration = fmPlaylist.reduce((acc, track) => acc + track.duration, 0);

    function getSyncedTrack() {
      const nowInSeconds = Math.floor(Date.now() / 1000);
      let offset = nowInSeconds % totalPlaylistDuration;
      
      for (let i = 0; i < fmPlaylist.length; i++) {
        const track = fmPlaylist[i];
        if (offset < track.duration) {
          return {
            track: track,
            startOffset: offset
          };
        }
        offset -= track.duration;
      }
      return {
        track: fmPlaylist[0],
        startOffset: 0
      };
    }

    function updatePlayerUI(isPlaying: boolean, trackTitle: string = "Doca FM Trực Tuyến 📻") {
      if (isPlaying) {
        playerContainer?.classList.add('playing');
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
        spotifyLink?.classList.remove('hidden');
        if (playerTitle) playerTitle.textContent = `📻 FM: ${trackTitle}`;
      } else {
        playerContainer?.classList.remove('playing');
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
        spotifyLink?.classList.add('hidden');
        if (playerTitle) playerTitle.textContent = "Doca FM Trực Tuyến 📻";
        if (playerStatus) playerStatus.textContent = "Đang tạm dừng...";
      }
    }

    function playSyncedRadio() {
      if (!audio) return;
      const { track, startOffset } = getSyncedTrack();
      
      audio.src = track.src;
      audio.currentTime = startOffset;
      
      audio.play().then(() => {
        updatePlayerUI(true, track.title);
        // Track the current playback seconds
        const updateStatus = () => {
          if (!audio.paused) {
            const currentSeconds = Math.floor(audio.currentTime);
            const minutes = Math.floor(currentSeconds / 60);
            const seconds = currentSeconds % 60;
            const timeStr = `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
            
            const totalMins = Math.floor(track.duration / 60);
            const totalSecs = track.duration % 60;
            const totalStr = `${totalMins}:${totalSecs < 10 ? '0' : ''}${totalSecs}`;
            
            if (playerStatus) playerStatus.textContent = `Đang phát (${timeStr} / ${totalStr})`;
            
            if (spotifyLink) {
              spotifyLink.setAttribute('href', track.spotifyUrl);
            }
            
            requestAnimationFrame(updateStatus);
          }
        };
        requestAnimationFrame(updateStatus);
      }).catch(err => {
        console.warn("Audio play failed, user gesture required:", err);
        updatePlayerUI(false);
      });
    }

    playBtn?.addEventListener('click', () => {
      if (!audio) return;
      if (audio.paused) {
        playSyncedRadio();
      } else {
        audio.pause();
        updatePlayerUI(false);
      }
    });

    audio?.addEventListener('ended', () => {
      // Automatically sync and transition to the next track in the playlist loop
      playSyncedRadio();
    });

    // --- 2. CATALOGUE FILTER & PAGINATION ---
    const tabBtns = document.querySelectorAll('.category-tabs-container .tab-btn');
    const productGrid = document.querySelector('.products-grid');
    const productCards = productGrid ? productGrid.children : [];
    const paginationContainer = document.getElementById('products-pagination');
    
    let currentCategory = 'all';
    let currentPage = 1;
    const itemsPerPage = 10;
    
    function updateGrid() {
      if (!productCards.length) return;

      // Filter product cards by category-raw attribute
      const filteredCards = Array.from(productCards).filter(card => {
        const cardInner = card.classList.contains('product-card-v2') ? card : card.querySelector('.product-card-v2');
        if (!cardInner) return false;
        const categoryRaw = cardInner.getAttribute('data-category-raw') || '';
        if (currentCategory === 'all') return true;
        return categoryRaw === currentCategory;
      });
      
      const totalItems = filteredCards.length;
      const totalPages = Math.ceil(totalItems / itemsPerPage);
      
      if (currentPage < 1) currentPage = 1;
      if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
      
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = startIndex + itemsPerPage;
      
      // Hide all first
      Array.from(productCards).forEach(card => {
        (card as HTMLElement).style.display = 'none';
      });
      
      // Show filtered page items
      filteredCards.forEach((card, index) => {
        if (index >= startIndex && index < endIndex) {
          (card as HTMLElement).style.display = 'block';
        }
      });
      
      // Render pagination
      renderPagination(totalPages);
    }
    
    function renderPagination(totalPages: number) {
      if (!paginationContainer) return;
      
      if (totalPages <= 1) {
        paginationContainer.innerHTML = '';
        paginationContainer.style.display = 'none';
        return;
      }
      
      paginationContainer.style.display = 'flex';
      let html = '';
      
      // Prev
      html += `<button class="page-btn prev-btn" ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}"><i class="ph-light ph-caret-left"></i></button>`;
      
      // Page numbers
      for (let i = 1; i <= totalPages; i++) {
        html += `<button class="page-btn num-btn ${currentPage === i ? 'active' : ''}" data-page="${i}">${i}</button>`;
      }
      
      // Next
      html += `<button class="page-btn next-btn" ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}"><i class="ph-light ph-caret-right"></i></button>`;
      
      paginationContainer.innerHTML = html;
      
      // Events
      paginationContainer.querySelectorAll('.page-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          if (target.disabled) return;
          const pageNum = parseInt(target.getAttribute('data-page') || '1');
          currentPage = pageNum;
          updateGrid();
          
          const shelfSection = document.querySelector('.shelf-section');
          shelfSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }
    
    // Tab event handlers
    tabBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        tabBtns.forEach(b => b.classList.remove('active'));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add('active');
        
        currentCategory = target.getAttribute('data-category') || 'all';
        currentPage = 1;
        updateGrid();
      });
    });
    
    // Initial run
    updateGrid();
  });
</script>
