---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "DOCA - Sống Chậm Cùng Thú Cưng", 
	description = "Nơi cùng chú thú cưng của bạn sống chậm mỗi ngày, chia sẻ yêu thương và nuôi dưỡng những ký ức chữa lành." 
} = Astro.props;
---

<!doctype html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/images/brand/symbol-green.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/images/brand/symbol-green.png" />
		<meta property="og:locale" content="vi_VN" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="/images/brand/symbol-green.png" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,400&family=Space+Mono:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
		
		<!-- Phosphor Icons CDN (Importing specific weights needed for Muji Minimalism) -->
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css" />
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/light/style.css" />
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/thin/style.css" />
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/fill/style.css" />
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/duotone/style.css" />
	</head>
	<body>
		<slot />

		<!-- Footer / Bottom Bar -->
		<footer class="cozy-footer">
			<div class="container footer-container">
				<span class="footer-copyright">&copy; 2026 doca.pet · Cùng Boss sống chậm</span>
				<div class="footer-socials">
					<a href="#" target="_blank" rel="noopener noreferrer" class="social-link" title="Youtube">
						<i class="ph-light ph-youtube-logo"></i>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" class="social-link" title="Facebook Page">
						<i class="ph-light ph-facebook-logo"></i>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" class="social-link" title="Facebook Group">
						<i class="ph-light ph-users-three"></i>
					</a>
					<a href="#" target="_blank" rel="noopener noreferrer" class="social-link" title="Tiktok">
						<i class="ph-light ph-tiktok-logo"></i>
					</a>
				</div>
			</div>
		</footer>

		<!-- Global Toast Container -->
		<div id="cozy-toast-element" class="cozy-toast"></div>

		<script>
			// Global Toast Notification Helper
			window.showToast = function(message) {
				const toast = document.getElementById('cozy-toast-element');
				if (toast) {
					toast.textContent = message;
					toast.classList.add('show');
					setTimeout(() => {
						toast.classList.remove('show');
					}, 4000);
				}
			}
		</script>
	</body>
</html>
