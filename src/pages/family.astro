---
import Layout from '../layouts/Layout.astro';
import familyData from '../data/family.json';

// Tải danh sách hình ảnh gia đình từ JSON
const familyPhotos = familyData;
---

<Layout 
  title="Góc Nhỏ Gia Đình | doca.pet" 
  description="Nơi cất giữ những khoảnh khắc ấm áp và mộc mạc của gia đình nhà DOCA. Mời cô chú lật xem từng bức ảnh chụp kỷ niệm của tụi con nhé. 🐾"
>
  <!-- Nhúng Google Fonts cho chữ viết tay mặt sau Polaroid -->
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;700&family=Patrick+Hand&display=swap" rel="stylesheet" />

  <main class="family-page-view">
    <!-- Navbar -->
    <nav class="navbar">
      <div class="container nav-container">
        <a href="/" class="logo-wrapper">
          <img src="/images/brand/logo-light.png" alt="doca.pet Logo" class="brand-logo-img" />
        </a>
        <div class="nav-right">
          <!-- Desktop navigation links -->
          <div class="nav-links-desktop">
            <a href="/about" class="nav-link-text">About Us</a>
            <a href="/product" class="nav-link-text">Sản phẩm</a>
            <a href="/family" class="nav-link-text active">Gia đình</a>
            <a href="/#blog-section" class="nav-link-text">Blog</a>
          </div>

          <!-- Hamburger toggle -->
          <button id="menu-toggle-btn" class="menu-toggle" aria-label="Menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
      <!-- Mobile navigation menu -->
      <div id="mobile-menu" class="mobile-menu">
        <div class="container mobile-menu-container">
          <a href="/about" class="mobile-menu-link"><i class="ph-light ph-info"></i> About Us</a>
          <a href="/product" class="mobile-menu-link"><i class="ph-light ph-circles-four"></i> Sản phẩm</a>
          <a href="/family" class="mobile-menu-link active"><i class="ph-light ph-users"></i> Gia đình</a>
          <a href="/#blog-section" class="mobile-menu-link"><i class="ph-light ph-book-open"></i> Blog</a>
        </div>
      </div>
    </nav>

    <div class="container content-container">
      <!-- Header góc gia đình -->
      <div class="family-header animate-fade-in">
        <h1 class="family-page-title">Góc Nhỏ Gia Đình</h1>
        <p class="family-page-subtitle animate-fade-in-delayed">
          mỗi bức ảnh là một lát cắt thời gian dịu êm mẹ Lin chụp cho tụi con...<br />
          cô chú nhấp nhẹ vào từng tấm ảnh để đọc những dòng nhật ký viết tay ở mặt sau nhé. 🐾
        </p>
      </div>

      <!-- Pinterest-style Masonry Grid -->
      <div class="family-masonry-grid">
        {familyPhotos.map((photo) => (
          <div class="polaroid-card" data-id={photo.id}>
            <div class="polaroid-card-inner">
              
              <!-- Mặt trước: Ảnh Polaroid truyền thống -->
              <div class="card-front">
                <div class="polaroid-frame">
                  <div class="photo-wrapper" style={`aspect-ratio: ${photo.aspectRatio || '1/1.2'};`}>
                    <img src={photo.imageUrl} alt={photo.title} class="polaroid-photo" loading="lazy" />
                  </div>
                  <div class="polaroid-caption">
                    <span class="caption-text">{photo.title}</span>
                  </div>
                </div>
              </div>

              <!-- Mặt sau: Ghi chú viết tay bút chì mộc mạc -->
              <div class="card-back">
                <div class="note-paper">
                  <div class="note-pattern">
                    <p class="note-handwritten">{photo.note}</p>
                    <div class="note-footer">
                      <span class="note-date">Lin & Mum 🐾</span>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  // Kích hoạt tính năng click/touch để lật ảnh (3D Flip toggle) và đóng mở mobile menu
  document.addEventListener('DOMContentLoaded', () => {
    // --- 1. MOBILE MENU TOGGLE ---
    const menuToggleBtn = document.getElementById('menu-toggle-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggleBtn?.addEventListener('click', () => {
      const isExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
      menuToggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      menuToggleBtn.classList.toggle('active');
      mobileMenu?.classList.toggle('active');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!menuToggleBtn?.contains(target) && !mobileMenu?.contains(target)) {
        menuToggleBtn?.setAttribute('aria-expanded', 'false');
        menuToggleBtn?.classList.remove('active');
        mobileMenu?.classList.remove('active');
      }
    });

    // --- 2. POLAROID CARD FLIP ---
    const cards = document.querySelectorAll('.polaroid-card');
    
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a') || target.closest('button')) return;
        
        const inner = card.querySelector('.polaroid-card-inner');
        if (inner) {
          inner.classList.toggle('is-flipped');
        }
      });
    });
  });
</script>

<style>
  .family-page-view {
    min-height: 100vh;
    background-color: var(--cozy-bg-beige);
    padding-bottom: 5rem;
  }

  /* Navbar Styles matching product.astro */
  .navbar {
    background-color: rgba(251, 250, 246, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cozy-border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0.5rem 0;
    box-shadow: 0 1px 3px rgba(21, 23, 15, 0.04);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .brand-logo-img {
    height: 24px;
    width: auto;
    display: block;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-link-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link-text:hover {
    color: var(--cozy-green-matcha-forest);
  }

  .nav-link-text.active {
    color: var(--cozy-green-matcha-forest) !important;
    font-weight: 700 !important;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
    transition: transform 0.3s ease;
  }

  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--cozy-text-obsidian);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links-desktop {
    display: none; /* Hidden on mobile */
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .nav-links-desktop {
      display: flex;
    }
    .menu-toggle {
      display: none; /* Hidden on desktop */
    }
  }

  /* Mobile menu dropdown */
  .mobile-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: rgba(251, 250, 246, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1.5px solid var(--cozy-border-light);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
    z-index: 95;
    box-shadow: 0 10px 20px rgba(21, 23, 15, 0.05);
  }

  .mobile-menu.active {
    max-height: 250px;
    opacity: 1;
  }

  .mobile-menu-container {
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--cozy-text-obsidian);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.8rem;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .mobile-menu-link:hover {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest);
  }

  .mobile-menu-link.active {
    background-color: var(--cozy-bg-oatmeal);
    color: var(--cozy-green-matcha-forest) !important;
  }

  .mobile-menu-link i {
    font-size: 1.2rem;
    color: var(--cozy-wood-sugi);
  }

  /* Content view layout spacing */
  .content-container {
    padding-top: 2rem;
  }

  /* Header chấn định */
  .family-header {
    text-align: center;
    margin-bottom: 2.5rem;
    position: relative;
  }

  .family-page-title {
    font-size: 1.85rem;
    font-weight: 800;
    color: var(--cozy-wood-kogecha);
    margin: 0 0 0.6rem 0;
    letter-spacing: -0.2px;
  }

  .family-page-subtitle {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #555558;
    opacity: 0.85;
    margin: 0;
  }

  /* Lưới so le Pinterest (Masonry Layout) */
  .family-masonry-grid {
    column-count: 5;
    column-gap: 1.25rem;
    width: 100%;
  }

  /* Breakpoints đáp ứng đúng yêu cầu: Mobile 2, Tablet 3, Desktop 5 */
  @media (max-width: 1023px) {
    .family-masonry-grid {
      column-count: 3;
      column-gap: 1rem;
    }
  }

  @media (max-width: 639px) {
    .family-masonry-grid {
      column-count: 2;
      column-gap: 0.75rem;
    }
  }

  /* Container thẻ Polaroid */
  .polaroid-card {
    break-inside: avoid;
    margin-bottom: 1.25rem;
    cursor: pointer;
    perspective: 1000px; /* Cần thiết cho chuyển động 3D xoay */
    position: relative;
  }

  /* Các độ nghiêng ngẫu nhiên mô phỏng ảnh trải trên bàn gỗ */
  .polaroid-card:nth-child(odd) {
    transform: rotate(-1.2deg);
  }
  .polaroid-card:nth-child(even) {
    transform: rotate(1.5deg);
  }
  .polaroid-card:nth-child(3n) {
    transform: rotate(-0.8deg);
  }
  .polaroid-card:nth-child(5n) {
    transform: rotate(1.8deg);
  }

  .polaroid-card:hover {
    z-index: 50;
    transform: scale(1.03) rotate(0deg);
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Wrapper xoay lật 3D */
  .polaroid-card-inner {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Trạng thái đã lật mặt sau */
  .polaroid-card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  /* Thiết kế chung cho cả hai mặt */
  .card-front, .card-back {
    width: 100%;
    backface-visibility: hidden; /* Ẩn mặt đối diện khi xoay */
    border-radius: 4px;
    box-shadow: 0 6px 16px rgba(139, 94, 60, 0.07);
    transition: box-shadow 0.3s ease;
  }

  .polaroid-card:hover .card-front,
  .polaroid-card:hover .card-back {
    box-shadow: 0 12px 24px rgba(139, 94, 60, 0.12);
  }

  .card-back {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    transform: rotateY(180deg); /* Lật sẵn mặt sau */
  }

  /* --- MẶT TRƯỚC: KHUNG ẢNH POLAROID --- */
  .polaroid-frame {
    background-color: var(--cozy-bg-pure);
    padding: 0.6rem 0.6rem 1.6rem 0.6rem; /* Viền dưới dày đặc trưng của Polaroid */
    border: 1px solid var(--cozy-border-light);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .photo-wrapper {
    width: 100%;
    overflow: hidden;
    background-color: var(--cozy-bg-beige);
    border-radius: 2px;
  }

  .polaroid-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .polaroid-caption {
    text-align: center;
    padding-top: 0.2rem;
  }

  .caption-text {
    font-family: 'Patrick Hand', sans-serif;
    font-size: 0.95rem;
    color: var(--cozy-wood-kogecha);
    letter-spacing: 0.5px;
  }

  /* --- MẶT SAU: GIẤY KRAFT GHI CHÚ VIẾT TAY --- */
  .card-back {
    background-color: #FAF6EE; /* Aged paper tone */
    border: 1px solid var(--cozy-border-light);
    border-radius: 4px;
  }

  .note-paper {
    width: 100%;
    height: 100%;
    padding: 1.2rem;
    display: flex;
    box-sizing: border-box;
  }

  /* Họa tiết kẻ ô ly hoặc sọc nhạt */
  .note-pattern {
    width: 100%;
    height: 100%;
    border: 1px dashed rgba(139, 94, 60, 0.15);
    border-radius: 2px;
    padding: 0.8rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
    background-image: radial-gradient(rgba(139, 94, 60, 0.1) 1px, transparent 1px);
    background-size: 14px 14px;
  }

  .note-handwritten {
    font-family: 'Caveat', cursive;
    font-size: 1.25rem;
    font-weight: 550;
    line-height: 1.45;
    color: #4A3E3D; /* Pencil grey-brown */
    margin: 0;
    text-align: center;
    word-break: break-word;
  }

  .note-footer {
    text-align: right;
    padding-top: 0.4rem;
    border-top: 1px dashed rgba(139, 94, 60, 0.12);
  }

  .note-date {
    font-family: 'Caveat', cursive;
    font-size: 1rem;
    font-weight: 700;
    color: var(--cozy-wood-sugi);
  }

  /* Animations */
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }

  .animate-fade-in-delayed {
    animation: fadeIn 0.8s ease-out 0.2s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
